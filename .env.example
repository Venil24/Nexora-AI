# ==========================================
# Nexora-AI Environment Variables Template
# Copy this file to .env and fill in values
# ==========================================

# ---- Flask Backend ----
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# ---- JWT Configuration ----
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production-min-32-chars
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# ---- MongoDB Atlas ----
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/nexora_ai?retryWrites=true&w=majority
MONGO_DB_NAME=nexora_ai

# ---- GitHub API ----
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# ---- Email (SMTP) ----
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here
MAIL_DEFAULT_SENDER=Nexora AI <your-email@gmail.com>

# ---- Frontend (Vite) ----
VITE_API_BASE_URL=http://localhost:5000/api
VITE_APP_NAME=Nexora AI
VITE_APP_VERSION=1.0.0

# ---- File Upload ----
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=10485760

# ---- ML Models ----
ML_MODELS_PATH=ml/trained_models
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# ---- CORS ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
